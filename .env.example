# Example environment configuration
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file to version control

# GCP Project Configuration
# Replace with your actual project ID
GCP_PROJECT_ID=your-project-id-here
GCP_REGION=us-central1
GCP_ZONE=us-central1-a

# GCP Authentication
# Path to service account key file (use absolute path)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account-key.json

# Alternative: Use Application Default Credentials
# GOOGLE_CLOUD_PROJECT=your-project-id-here

# Optional: Quota project for billing
# GCP_QUOTA_PROJECT_ID=your-quota-project-id

# Optional: Service account impersonation
# GCP_IMPERSONATE_SERVICE_ACCOUNT=service-account@project.iam.gserviceaccount.com

# API Configuration
GCP_TIMEOUT=30
GCP_MAX_RETRIES=3

# Multi-Project Support (optional)
# GCP_PROD_PROJECT_ID=prod-project-id
# GCP_PROD_CREDENTIALS=/path/to/prod-key.json
# GCP_DEV_PROJECT_ID=dev-project-id  
# GCP_DEV_CREDENTIALS=/path/to/dev-key.json

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# Development Settings
DEBUG=false
DEVELOPMENT_MODE=false

# Security Settings
ENABLE_AUDIT_LOGGING=true
ENABLE_COST_TRACKING=true
BUDGET_ALERT_THRESHOLD=1000.0

# Feature Flags
ENABLE_VERTEX_AI=true
ENABLE_BIG_QUERY=true
ENABLE_CLOUD_FUNCTIONS=true
ENABLE_GKE=true
ENABLE_CLOUD_RUN=true